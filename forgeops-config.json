{
  "version": "2.0",
  "org": "askboppana",
  "projects": {
    "uipath-rpa": {
      "repos": ["uipath-claims-bot", "uipath-invoice-bot", "uipath-onboarding-bot"],
      "template": "uipath-rpa",
      "team": "RPA Team",
      "environments": ["qa", "stage", "prod"]
    },
    "java-backend": {
      "repos": ["api-gateway", "user-service", "payment-service"],
      "template": "java-webapp",
      "team": "Backend Team",
      "environments": ["int", "qa", "stage", "prod"]
    },
    "react-frontend": {
      "repos": ["customer-portal", "admin-dashboard"],
      "template": "javascript-webapp",
      "team": "Frontend Team",
      "environments": ["int", "qa", "stage", "prod"]
    },
    "system-integration": {
      "repos": ["data-sync-service", "event-processor"],
      "template": "system-integration",
      "team": "Integration Team",
      "environments": ["int", "qa", "stage", "prod"]
    }
  },
  "roles": {
    "admin": {"description": "Full control", "permissions": ["all"]},
    "release_engineer": {"description": "Deploy and promote between environments", "permissions": ["view_all", "create_pr", "merge_pr", "deploy", "promote", "rollback"]},
    "developer": {"description": "Commit code, create PRs to INT", "permissions": ["view_own", "create_pr_to_int", "run_pipeline", "view_logs"]},
    "tech_lead": {"description": "Review and approve PRs", "permissions": ["view_all", "approve_pr", "merge_pr", "approve_int"]},
    "qa_team": {"description": "View QA environment, update SIT status", "permissions": ["view_qa", "update_jira_sit"]},
    "uat_team": {"description": "View Stage environment, update UAT status", "permissions": ["view_stage", "update_jira_uat"]}
  },
  "users": {
    "askboppana": {"role": "admin", "name": "Ashwin Boppana", "email": ""}
  },
  "email_groups": {
    "developers": [],
    "qa_team": [],
    "uat_team": [],
    "release_engineers": [],
    "all_stakeholders": []
  }
}
